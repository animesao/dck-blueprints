{
  "name": "minecraft-server",
  "category": "games",
  "description": "Minecraft Java Edition server with persistent world",
  "image": "itzg/minecraft-server",
  "tag": "latest",
  "command": "",
  "env": "[{\"key\":\"EULA\",\"value\":\"TRUE\"},{\"key\":\"VERSION\",\"value\":\"LATEST\"},{\"key\":\"DIFFICULTY\",\"value\":\"normal\"},{\"key\":\"MODE\",\"value\":\"survival\"},{\"key\":\"MAX_PLAYERS\",\"value\":\"10\"},{\"key\":\"MOTD\",\"value\":\"Welcome to dck Minecraft!\"}]",
  "ports": "25565:25565/tcp,25565:25565/udp",
  "volumes": "minecraft_data:/data",
  "memory": "2g",
  "cpus": "2.0",
  "restart": "always"
}
