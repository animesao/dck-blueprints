{
  "name": "grafana",
  "category": "monitoring",
  "description": "Grafana — dashboards and observability platform",
  "image": "grafana/grafana",
  "tag": "latest",
  "command": "",
  "env": "[{\"key\":\"GF_SECURITY_ADMIN_USER\",\"value\":\"admin\"},{\"key\":\"GF_SECURITY_ADMIN_PASSWORD\",\"value\":\"admin123\"},{\"key\":\"GF_INSTALL_PLUGINS\",\"value\":\"\"}]",
  "ports": "3000:3000/tcp",
  "volumes": "grafana_data:/var/lib/grafana",
  "memory": "256m",
  "cpus": "0.5",
  "restart": "always"
}